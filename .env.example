# ============================================================
# Platform Configuration — copy this to .env and fill in
# ============================================================

# Your domain (e.g. myplatform.com)
# Set up a wildcard DNS record: *.myplatform.com → your server IP
PLATFORM_DOMAIN=myplatform.com

# Claude API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Database (auto-configured if using docker-compose)
POSTGRES_USER=platform
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=platform
DATABASE_URL=postgresql://platform:changeme_strong_password@db:5432/platform

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=changeme_random_secret
